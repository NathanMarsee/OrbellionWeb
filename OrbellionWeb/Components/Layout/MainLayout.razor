@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <AuthorizeView>
            <Authorized>
                <form class="top-row px-4" method="post" action="/Account/Logout" enctype="multipart/form-data">
                    <AntiforgeryToken />
                    <input type="hidden" name="returnUrl" value=""/>
                    <button type="submit" class="nav-link btn btn-link">Logout</button>
                </form>
            </Authorized>
            <NotAuthorized>
                <a class="top-row px-4" href="Account/Login">Login</a>
            </NotAuthorized>
        </AuthorizeView>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
