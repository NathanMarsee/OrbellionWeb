@using OrbellionWeb.Shared
@using Microsoft.JSInterop
@inject IJSRuntime JS;

<div class="@CardClass" id="@DisplayedCard.Id.ToString()" @ref="cardElement">
    <div class="title"><textarea type="text" @bind="@DisplayedCard.Name" placeholder="Card Name" rows="1"/></div>
    <div class="cardart"><br></div>
    <div class="typeline">
        <InputSelect @bind-Value="@DisplayedCard.Element" style="border: none;">
            @foreach (var value in Enum.GetValues(typeof(Element)))
            {
                <option value="@value">@value</option>
            }
        </InputSelect>
        <InputSelect @bind-Value="@DisplayedCard.Type" style="border: none;">
            @foreach (var value in Enum.GetValues(typeof(CardType)))
            {
                <option value="@value">@value</option>
            }
        </InputSelect><br>
        
    </div>
    <div class="text">
        @if (DisplayedCard.Type == CardType.Move || DisplayedCard.Type == CardType.Item)
        {
            <InputSelect @bind-Value="@DisplayedCard.Power" style="border: none; font-weight: 700;">
                @foreach (var value in Enum.GetValues(typeof(Power)))
                {
                    <option value="@value">@value</option>
                }
            </InputSelect>
            <br>
            <textarea type="text" @bind="@DisplayedCard.Text" placeholder="Card Text" rows="4"/>
        }
        else {
            <textarea type="text" @bind="@DisplayedCard.Text" placeholder="Card Text" rows="5"/>
        }
    </div>
</div>

@code {
    [Parameter]
    public Card DisplayedCard { get; set; } = new Card();

    // Raised when this card is dropped into the dropzone.
    [Parameter]
    public EventCallback<Guid> OnDropped { get; set; }

    [Parameter]
    public String CardClass { get; set; } = "card";

    private ElementReference cardElement;
    private DotNetObjectReference<CardVisual>? dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // ensure drag behavior is wired (ok to call multiple times)
        await JS.InvokeVoidAsync("dragAndDrop", ".battlefieldCard");
        await JS.InvokeVoidAsync("dropZone", ".dropzone");

        // register this instance with JS so drops call back here
        dotNetRef ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("registerDropHandler", cardElement, dotNetRef);

        if (firstRender)
        {
            await JS.InvokeVoidAsync("bringElementToFront", cardElement);
        }
    }

    [JSInvokable]
    public async Task NotifyDropped(string id)
    {
        if (Guid.TryParse(id, out var guid))
        {
            await OnDropped.InvokeAsync(guid);
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            // unregister the JS callback mapping for this element to avoid stale mappings
            await JS.InvokeVoidAsync("unregisterDropHandler", cardElement);
        }
        catch
        {
            // best-effort cleanup; swallow exceptions during dispose
        }
        dotNetRef?.Dispose();
    }
}
