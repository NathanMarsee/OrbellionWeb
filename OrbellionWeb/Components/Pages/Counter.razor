@page "/battlefield"
@using Microsoft.AspNetCore.Authorization
@using OrbellionWeb.Components.UIElements
@using OrbellionWeb.Models
@using OrbellionWeb.Shared
@rendermode InteractiveServer
@attribute [Authorize]

<PageTitle>Battlefield</PageTitle>

<h1>Cards</h1>

<button class="btn btn-primary" @onclick="AddCard">New Card</button>

<div class="battlefield dropzonebattlefield" style="width: auto; max-width: 80%; height: 800px; background-color: lightgray;">
    @foreach (var card in battlefieldCards)
    {
        <CardVisual @key="card.Id" DisplayedCard="card" CardClass="battlefieldCard card no-select" OnDropped="@OnBattlefieldCardDropped"></CardVisual>
    }
</div>
<div class="hand dropzonehand" style="width: auto; max-width: 80%; min-height: 250px; background-color: gray; display: flex; overflow-x: auto; white-space: nowrap; padding: 10px;">
    <SortableList Items="handCards" Context="card" OnUpdate="SortList" Filter="select, input, textarea, option, .no-drag" ContainerStyle="display:flex; gap:10px; align-items:flex-start;">
        <SortableItemTemplate>
            <CardVisual @key="card.Id" DisplayedCard="card" CardClass="handCard card no-select" OnDropped="@OnHandCardDropped"></CardVisual>
        </SortableItemTemplate>
    </SortableList>
</div>

@code {
    private List<Card> battlefieldCards = new List<Card>();
    private List<Card> handCards = new List<Card>();

    private void AddCard()
    {
        handCards.Add(new Card());
    }

    private async Task OnBattlefieldCardDropped(Guid cardId)
    {
        var card = battlefieldCards.FirstOrDefault(c => c.Id == cardId);
        if (card != null)
        {
            battlefieldCards.Remove(card);
            handCards.Add(card);
            await InvokeAsync(StateHasChanged);
        }
    }
    private async Task OnHandCardDropped(Guid cardId)
    {
        var card = handCards.FirstOrDefault(c => c.Id == cardId);
        if (card != null)
        {
            handCards.Remove(card);
            battlefieldCards.Add(card);
            await InvokeAsync(StateHasChanged);
        }
    }
    private async Task SortList((int oldIndex, int newIndex) args)
    {
        var card = handCards[args.oldIndex];
        handCards.RemoveAt(args.oldIndex);
        handCards.Insert(args.newIndex, card);
        await InvokeAsync(StateHasChanged);
    }
}
